          { "id": "steel", "E": 2.1e11, "G": 8.1e10, "nu": 0.3, "rho": 7850, "sigma_yield": 245e6 }
        ],
        "sections": [
          { "id": "i20", "A": 26.8e-4, "I_z": 1840e-8, "I_y": 115e-8, "W_z": 184e-6, "h": 0.2, "shear_area_y": 13.4e-4 }
        ],
        "nodes": [
          { "id": "n1", "coords": [0, 0, 0] },
          { "id": "nM", "coords": [3.0, 0, 0] },
          { "id": "n2", "coords": [6.0, 0, 0] }
        ],
        "elements": [
          { "id": "e1", "node_start": "n1", "node_end": "nM", "material_id": "steel", "section_id": "i20" },
