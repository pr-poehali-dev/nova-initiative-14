{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing action returns 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "missing_action"},
      "bodyMatcher": "partial"
    },
    {
      "name": "List without auth returns 401",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 401,
      "expectedBody": {"error": "unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Save without auth returns 401",
      "method": "POST",
      "path": "/?action=save",
      "body": {"id": 1, "content": "x"},
      "expectedStatus": 401,
      "expectedBody": {"error": "unauthorized"},
      "bodyMatcher": "partial"
    }
  ]
}
