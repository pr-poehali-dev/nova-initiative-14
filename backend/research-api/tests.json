{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing action returns 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "missing_action"},
      "bodyMatcher": "partial"
    },
    {
      "name": "List without auth returns 401",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 401,
      "expectedBody": {"error": "unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Save without auth returns 401",
      "method": "POST",
      "path": "/?action=save",
      "body": {"id": 1, "content": "x"},
      "expectedStatus": 401,
      "expectedBody": {"error": "unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Expenses list without auth returns 401",
      "method": "GET",
      "path": "/?action=expenses-list",
      "expectedStatus": 401,
      "expectedBody": {"error": "unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Mindmap get without auth returns 401",
      "method": "POST",
      "path": "/?action=mindmap-get",
      "body": {"default_data": {"nodes": [], "edges": []}},
      "expectedStatus": 401,
      "expectedBody": {"error": "unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Finance get without auth returns 401",
      "method": "POST",
      "path": "/?action=finance-get",
      "body": {"default_data": {}},
      "expectedStatus": 401,
      "expectedBody": {"error": "unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Bizplan get without auth returns 401",
      "method": "POST",
      "path": "/?action=bizplan-get",
      "body": {"default_data": {}},
      "expectedStatus": 401,
      "expectedBody": {"error": "unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Presets list without auth returns 401",
      "method": "GET",
      "path": "/?action=presets-list",
      "expectedStatus": 401,
      "expectedBody": {"error": "unauthorized"},
      "bodyMatcher": "partial"
    }
  ]
}