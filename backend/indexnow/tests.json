{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "List all pages with index status",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Empty submit rejected",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "no_valid_urls"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Custom urls submitted",
      "method": "POST",
      "path": "/",
      "body": {"urls": ["/cae/raschet-balki-onlayn"]},
      "expectedStatus": 200,
      "expectedBody": {"sent_count": 1},
      "bodyMatcher": "partial"
    }
  ]
}
