{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/?action=list",
      "expectedStatus": 200
    },
    {
      "name": "List without auth → 401",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 401,
      "expectedBody": { "error": "unauthorized" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Unread count without auth → 401",
      "method": "GET",
      "path": "/?action=unread-count",
      "expectedStatus": 401,
      "expectedBody": { "error": "unauthorized" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Публичный журнал версий доступен без авторизации",
      "method": "GET",
      "path": "/?action=changelog-list&limit=5",
      "expectedStatus": 200
    }
  ]
}