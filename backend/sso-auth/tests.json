{
  "tests": [
    {
      "name": "OPTIONS возвращает CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Без action возвращает 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Регистрация с некорректным email",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "not-an-email", "password": "verylongpassword123"},
      "expectedStatus": 400
    },
    {
      "name": "Регистрация с коротким паролем",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "ok@example.com", "password": "123"},
      "expectedStatus": 400
    },
    {
      "name": "Логин без данных",
      "method": "POST",
      "path": "/?action=login",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Логин с несуществующим аккаунтом",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "no-such-user-xyz@example.com", "password": "anything12345"},
      "expectedStatus": 401
    },
    {
      "name": "Userinfo без токена",
      "method": "GET",
      "path": "/?action=userinfo",
      "expectedStatus": 401
    },
    {
      "name": "Refresh без токена",
      "method": "POST",
      "path": "/?action=refresh",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Повторная отправка — несуществующий email (всегда 200)",
      "method": "POST",
      "path": "/?action=resend-verification",
      "body": {"email": "no-such-user-xyz@example.com"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Запрос сброса — несуществующий email (всегда 200)",
      "method": "POST",
      "path": "/?action=request-reset",
      "body": {"email": "no-such-user-xyz@example.com"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Сброс пароля — невалидный токен",
      "method": "POST",
      "path": "/?action=reset-password",
      "body": {"token": "invalidtoken", "password": "newpassword123"},
      "expectedStatus": 400,
      "expectedBody": {"error": "invalid_token"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Сброс пароля — короткий пароль",
      "method": "POST",
      "path": "/?action=reset-password",
      "body": {"token": "sometoken", "password": "short"},
      "expectedStatus": 400,
      "expectedBody": {"error": "weak_password"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список способов входа без токена",
      "method": "GET",
      "path": "/?action=identities",
      "expectedStatus": 401
    },
    {
      "name": "Отвязка способа входа без токена",
      "method": "POST",
      "path": "/?action=identity-unlink",
      "body": {"provider": "google"},
      "expectedStatus": 401
    },
    {
      "name": "Обновление профиля без токена",
      "method": "POST",
      "path": "/?action=update-profile",
      "body": {"full_name": "Тест"},
      "expectedStatus": 401
    },
    {
      "name": "Смена пароля без токена",
      "method": "POST",
      "path": "/?action=change-password",
      "body": {"new_password": "newpassword123"},
      "expectedStatus": 401
    },
    {
      "name": "Список пользователей без токена",
      "method": "GET",
      "path": "/?action=admin-users",
      "expectedStatus": 401
    },
    {
      "name": "Смена роли без токена",
      "method": "POST",
      "path": "/?action=admin-set-role",
      "body": {"user_id": 1, "field": "is_admin", "value": true},
      "expectedStatus": 401
    },
    {
      "name": "Блокировка без токена",
      "method": "POST",
      "path": "/?action=admin-toggle-active",
      "body": {"user_id": 1, "value": false},
      "expectedStatus": 401
    },
    {
      "name": "Начисление баллов без токена",
      "method": "POST",
      "path": "/?action=admin-award-points",
      "body": {"user_id": 1, "points": 10},
      "expectedStatus": 401
    }
  ]
}